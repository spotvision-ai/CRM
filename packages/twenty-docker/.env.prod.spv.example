# SPOTVISION production .env template — copy to /opt/spotvision/twenty/.env
# on the VM and fill every real value before the first `docker compose up`.
# Secrets here must never be committed to git.

# ── Image source ──────────────────────────────────────────────────────────
# Account + region come from your AWS console. Example:
#   ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
ECR_REGISTRY=
# Default to `latest`; the deploy workflow overrides this inline with the
# semver tag being released. Changing this file lets you pin a specific
# version outside of CI (e.g. for ad-hoc rollbacks on the VM).
TAG=latest

# ── AWS region (used by awslogs driver) ───────────────────────────────────
AWS_REGION=us-east-1

# ── Database (RDS) ────────────────────────────────────────────────────────
# Full Postgres URL. Use the writer endpoint — Twenty runs migrations on
# startup which need write access. The db name is `default` by convention.
PG_DATABASE_URL=postgres://<user>:<password>@<rds-endpoint>:5432/default
DISABLE_DB_MIGRATIONS=false
DISABLE_CRON_JOBS_REGISTRATION=false

# ── Redis ─────────────────────────────────────────────────────────────────
# Defaults to the containerised redis on the same compose network.
REDIS_URL=redis://redis:6379

# ── App runtime ───────────────────────────────────────────────────────────
# Public origin — used for OAuth callbacks, email links, etc.
SERVER_URL=https://crm.spotvision.ai
# openssl rand -hex 32 — must be stable across server restarts or user
# sessions get invalidated.
APP_SECRET=

# ── File storage (S3) ─────────────────────────────────────────────────────
STORAGE_TYPE=s3
STORAGE_S3_REGION=us-east-1
STORAGE_S3_NAME=spotvision-twenty-uploads
# Leave empty unless using a non-AWS S3-compatible endpoint (Cloudflare R2,
# MinIO, etc.) — AWS S3 is resolved from the bucket name + region.
STORAGE_S3_ENDPOINT=

# ── Optional providers ────────────────────────────────────────────────────
# Uncomment on the VM as they are wired up. Both compose services already
# reference these env keys.
# MESSAGING_PROVIDER_GMAIL_ENABLED=true
# CALENDAR_PROVIDER_GOOGLE_ENABLED=true
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_CALLBACK_URL=https://crm.spotvision.ai/auth/google/redirect
# AUTH_GOOGLE_APIS_CALLBACK_URL=https://crm.spotvision.ai/auth/google-apis/get-access-token

# EMAIL_FROM_ADDRESS=contact@spotvision.ai
# EMAIL_FROM_NAME="SPOTVISION CRM"
# EMAIL_DRIVER=smtp
# EMAIL_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=
